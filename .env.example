MAC_MINI_TAILSCALE_DNS=nicolaws-mac-mini.example.ts.net
MAC_MINI_SSH_USER=nicolaw
MAC_MINI_SSH_PASSWORD=replace-me
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_ALLOWED_USERS=123456789
TELEGRAM_HOME_CHANNEL=123456789
